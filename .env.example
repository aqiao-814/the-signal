# Copy to .env and fill in. Safe defaults let the app run with zero secrets.

# Database (embedded PGlite socket server on :5433 by default)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/postgres?sslmode=disable&connection_limit=1&pgbouncer=true"

# Auth — generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-with-openssl-rand-hex-32"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# X (Twitter) API — optional. Empty => mock mode (seeded fixtures).
X_API_BEARER_TOKEN=""
INGEST_MODE="mock" # mock | live
# Reply-analysis depth (only used in live mode).
X_REPLY_LOOKUPS="4"   # top tweets to fetch replies for (1 API call each)
X_REPLY_PAGE="50"     # replies per call, up to 100 (deeper analysis, same cost)
X_RATE_PER_MIN="50"   # client request budget
X_CREDIT_BUDGET="100" # app-side credit budget shown in the credits meter

# AI summaries — provider swappable: template | anthropic | openai | gemini | huggingface
# For huggingface, AI_MODEL defaults to an instruct model on the HF router.
AI_PROVIDER="template"
AI_MODEL=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
GEMINI_API_KEY=""
HUGGINGFACE_API_KEY=""

# Jobs
CRON_SECRET="replace-with-random"
INTERNAL_JOB_SECRET="replace-with-random"
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

LOG_LEVEL="info"
NODE_ENV="development"
